<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="400.0" minWidth="600.0" prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.malek.pos.controllers.QuotesController">
   <top>
      <VBox spacing="10.0" style="-fx-padding: 15; -fx-background-color: #2c3e50;">
         <children>
            <Label text="Quote Management" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </top>
   <center>
      <VBox spacing="10.0" style="-fx-padding: 10;">
         <children>
            <TableView fx:id="tblQuotes" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="75.0" text="Quote ID" />
                <TableColumn fx:id="colDate" prefWidth="150.0" text="Date" />
                  <TableColumn fx:id="colCustomer" prefWidth="250.0" text="Customer" />
                  <TableColumn fx:id="colTotal" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;" text="Total" />
                  <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
              </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button onAction="#onDelete" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Delete Quote" />
                  <Button onAction="#onReprint" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Reprint" />
                  <Button defaultButton="true" onAction="#onLoad" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="Load to Sale" />
                  <Button onAction="#onClose" text="Close" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
