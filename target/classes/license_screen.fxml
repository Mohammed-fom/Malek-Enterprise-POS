<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="300.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.malek.pos.controllers.LicenseController">
   <children>
      <VBox alignment="CENTER" layoutX="50.0" layoutY="30.0" prefHeight="240.0" prefWidth="300.0" spacing="15.0">
         <children>
            <Label text="Software Activation">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <Label text="Please enter your subscription key to continue." wrapText="true" />
            <TextField fx:id="txtLicenseKey" promptText="Enter Subscription Key..." />
            <Button mnemonicParsing="false" onAction="#handleActivate" prefWidth="150.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Activate" />
            <Button mnemonicParsing="false" onAction="#handleExit" prefWidth="150.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Exit Application" />
            <Label fx:id="lblStatus" textFill="RED" />
         </children>
      </VBox>
   </children>
</AnchorPane>
