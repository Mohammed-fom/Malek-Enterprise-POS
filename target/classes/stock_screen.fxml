<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #f4f6f7;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.malek.pos.controllers.StockController">
    <top>
        <VBox spacing="10.0" style="-fx-padding: 20; -fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="header-label" text="STOCK MASTER FILE" textFill="WHITE" />
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="txtSearch" prefHeight="30.0" prefWidth="400.0" promptText="Search Description or Scan Barcode..." />
                        <Button mnemonicParsing="false" onAction="#onSearch" styleClass="action-button" text="Search" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tblProducts" styleClass="table-view" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colProductCode" prefWidth="100.0" text="Product Code" />
                <TableColumn fx:id="colDescription" prefWidth="300.0" text="Description" />
                <TableColumn fx:id="colCategory" prefWidth="120.0" text="Category" />
                <TableColumn fx:id="colCostExcl" prefWidth="80.0" text="Cost (Excl)" visible="false" />
                <TableColumn fx:id="colCost" prefWidth="80.0" text="Cost (Incl)" />
                <TableColumn fx:id="colRetailExcl" prefWidth="80.0" text="Retail (Excl)" visible="false" />
                <TableColumn fx:id="colRetail" prefWidth="80.0" text="Retail (Incl)" />
                <TableColumn fx:id="colTrade" prefWidth="80.0" text="Trade Price" />
                <TableColumn fx:id="colStock" prefWidth="80.0" text="Stock On Hand" />
                <TableColumn fx:id="colService" prefWidth="60.0" text="Service" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
    </center>
    <bottom>
        <VBox spacing="10.0" style="-fx-padding: 10; -fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <children>
                <!-- Row 1: Primary Actions -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onAddProduct" styleClass="action-button" text="Add Product" />
                        <Button mnemonicParsing="false" onAction="#onEditProduct" styleClass="secondary-button" text="Edit Product" />
                        <Button mnemonicParsing="false" onAction="#onDeleteProduct" styleClass="danger-button" text="Delete Product" />
                        <Button mnemonicParsing="false" onAction="#onReceiveStock" styleClass="success-button" text="Receive Stock" />
                        <Button mnemonicParsing="false" onAction="#onStockAdjustment" style="-fx-background-color: #8e44ad; -fx-text-fill: white;" styleClass="button" text="Adjust Stock" />
                        <Button mnemonicParsing="false" onAction="#onImportExcel" style="-fx-background-color: #34495e; -fx-text-fill: white;" styleClass="button" text="Import Excel" />
                        <Button mnemonicParsing="false" onAction="#onPrintLabel" styleClass="action-button" text="Print Label" />
                    </children>
                </HBox>
                <!-- Row 2: Secondary Actions & Status -->
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onViewHistory" styleClass="action-button" text="History" />
                        <Button mnemonicParsing="false" onAction="#onColumnFilter" styleClass="action-button" text="Columns" />
                        <Button mnemonicParsing="false" onAction="#onRefresh" styleClass="secondary-button" text="Refresh List" />
                        <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-weight: bold;" text="Values:" />
                        <Label fx:id="lblTotalCostValue" text="Cost: R0.00" textFill="#2c3e50" />
                        <Label fx:id="lblTotalRetailValue" text="Retail: R0.00" textFill="#2c3e50" />
                        <Button mnemonicParsing="false" onAction="#onClose" styleClass="danger-button" text="Close" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </bottom>
</BorderPane>
