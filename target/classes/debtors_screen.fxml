<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f4f6f7;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.malek.pos.controllers.DebtorsController">
    <top>
        <VBox spacing="10.0" style="-fx-padding: 20; -fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="header-label" text="DEBTORS MASTER FILE" textFill="WHITE" />
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="txtSearch" prefHeight="30.0" prefWidth="300.0" promptText="Search Name or Account No..." />
                        <Button mnemonicParsing="false" onAction="#onSearch" styleClass="action-button" text="Search" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tblDebtors" styleClass="table-view" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colAccount" prefWidth="100.0" text="Account No" />
                <TableColumn fx:id="colName" prefWidth="250.0" text="Customer Name" />
                <TableColumn fx:id="colPhone" prefWidth="120.0" text="Phone" />
                <TableColumn fx:id="colBalance" prefWidth="120.0" text="Current Balance" />
                <TableColumn fx:id="colLimit" prefWidth="120.0" text="Credit Limit" />
                <TableColumn fx:id="colTier" prefWidth="100.0" text="Price Tier" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 10; -fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#onAddDebtor" styleClass="action-button" text="Add Debtor" />
                <Button mnemonicParsing="false" onAction="#onEditDebtor" styleClass="secondary-button" text="Edit Debtor" />
                <Button mnemonicParsing="false" onAction="#onPayment" style="-fx-background-color: #8e44ad; -fx-text-fill: white;" styleClass="button" text="Payment" />
                <Button mnemonicParsing="false" onAction="#onHistory" style="-fx-background-color: #16a085; -fx-text-fill: white;" styleClass="button" text="History" />
                <Button mnemonicParsing="false" onAction="#onViewStatement" styleClass="success-button" text="View Statement" />
                <Button mnemonicParsing="false" onAction="#onSelectForSale" style="-fx-background-color: #e67e22; -fx-text-fill: white;" styleClass="button" text="Select for Sale" />
                <Button mnemonicParsing="false" onAction="#onClose" styleClass="danger-button" text="Close" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
