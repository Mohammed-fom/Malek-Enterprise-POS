<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.malek.pos.controllers.ReceiptPreviewController" prefHeight="700.0" prefWidth="500.0">
    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 10; -fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
            <Button fx:id="btnPrint" text="Print Receipt" onAction="#onPrint" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button fx:id="btnClose" text="Close" onAction="#onClose"/>
        </HBox>
    </bottom>
</BorderPane>
