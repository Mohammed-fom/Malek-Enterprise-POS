<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #34495e; -fx-padding: 10;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.malek.pos.controllers.UniversalSearchController">
    <top>
        <VBox spacing="5" style="-fx-padding: 0 0 10 0;">
            <Label text="UNIVERSAL DOCUMENT RECALL" textFill="WHITE">
                <font><Font name="System Bold" size="18"/></font>
            </Label>
            <TextField fx:id="txtSearch" promptText="Type to Search (ID, Name, Date)..." style="-fx-font-size: 14; -fx-padding: 8;"/>
        </VBox>
    </top>
    
    <center>
        <TableView fx:id="tblResults" style="-fx-font-size: 13;">
            <columns>
                <TableColumn fx:id="colType" text="Type" prefWidth="80"/>
                <TableColumn fx:id="colId" text="Document ID" prefWidth="120"/>
                <TableColumn fx:id="colDesc" text="Description" prefWidth="200"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="150"/>
                <TableColumn fx:id="colAmount" text="Amount" prefWidth="100"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>
    
    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Label text="Double-click to Open" textFill="#bdc3c7"/>
            <Button text="Open / View" onAction="#onOpen" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Close (ESC)" onAction="#onClose" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>
