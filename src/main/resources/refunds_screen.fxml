<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.malek.pos.controllers.RefundsController">
   <top>
      <VBox spacing="10.0" style="-fx-background-color: #c0392b; -fx-padding: 15;" BorderPane.alignment="CENTER">
         <children>
            <Label text="REFUND / RETURN" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="Original Receipt #:" textFill="WHITE">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtSearchId" onAction="#onSearch" promptText="e.g. SALE12012601" prefWidth="200.0" />
                  <Button onAction="#onSearch" text="Find Receipt" />
                  <Label text="OR" textFill="white" style="-fx-font-weight: bold;"/>
                  <TextField fx:id="txtAddItem" onAction="#onAddItem" promptText="Scan Barcode / Search Item..." prefWidth="200.0" />
                  <Button onAction="#onAddItem" text="Add Item" />
                  <Label text="|" textFill="white" style="-fx-font-weight: bold;"/>
                  <Button onAction="#onSelectCustomer" text="Select Customer" style="-fx-background-color: #f1c40f; -fx-text-fill: black;" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <VBox spacing="10.0" style="-fx-padding: 10;" BorderPane.alignment="CENTER">
         <children>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label fx:id="lblOriginalDetails" text="No Receipt Loaded" textFill="#7f8c8d">
                   <font>
                      <Font name="System Bold" size="14.0" />
                   </font>
                </Label>
                <Label text="Reason:" />
                <javafx.scene.control.ComboBox fx:id="cmbReason" prefWidth="150" promptText="Select Reason" />
                <javafx.scene.control.CheckBox fx:id="chkRestock" text="Return to Stock?" selected="true" />
            </HBox>

            <TableView fx:id="tblRefundItems" editable="true" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colDesc" prefWidth="250.0" text="Description" />
                  <TableColumn fx:id="colSoldQty" prefWidth="80.0" text="Sold Qty" style="-fx-alignment: CENTER-RIGHT;"/>
                  <TableColumn fx:id="colPrice" prefWidth="100.0" text="Unit Price" style="-fx-alignment: CENTER-RIGHT;"/>
                  <TableColumn fx:id="colReturnQty" prefWidth="100.0" text="Return Qty" style="-fx-alignment: CENTER-RIGHT; -fx-background-color: #ecf0f1;"/>
                  <TableColumn fx:id="colTotalRefund" prefWidth="120.0" text="Refund Amt" style="-fx-alignment: CENTER-RIGHT; font-weight: bold;"/>
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-padding: 15; -fx-background-color: #dfe6e9;" BorderPane.alignment="CENTER">
         <children>
            <Label text="TOTAL REFUND:">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label fx:id="lblTotalRefund" text="0.00" textFill="#c0392b">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
            
            <Button onAction="#onRefundCash" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" text="CASH REFUND" />
            <Button onAction="#onRefundCard" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-cursor: hand;" text="CARD REFUND" />
            <Button fx:id="btnAccountRefund" onAction="#onRefundAccount" disable="true" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-cursor: hand;" text="ACCOUNT REFUND" />

            <Button onAction="#onClose" prefHeight="40.0" prefWidth="80.0" text="Cancel" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
