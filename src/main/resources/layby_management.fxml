<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #ecf0f1; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.malek.pos.controllers.LaybyManagementController">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0;">
            <Label text="Layby Management" textFill="#2c3e50">
                <font><Font name="System Bold" size="24"/></font>
            </Label>
            <TextField fx:id="txtSearch" promptText="Search Layby ID or Customer Name" prefWidth="300" />
            <Button text="Search" onAction="#onSearch" />
        </HBox>
    </top>
    
    <center>
        <TableView fx:id="tblLaybys">
            <columns>
                <TableColumn fx:id="colId" text="Layby ID" prefWidth="120"/>
                <TableColumn fx:id="colCustomer" text="Customer" prefWidth="150"/>
                <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
                <TableColumn fx:id="colPaid" text="Paid" prefWidth="100"/>
                <TableColumn fx:id="colBalance" text="Balance" prefWidth="100"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                <TableColumn fx:id="colExpiry" text="Expiry Date" prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>
    
    <right>
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <Label text="Selected Layby Items" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
            <TableView fx:id="tblItems" prefWidth="250" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colItemName" text="Item" prefWidth="150"/>
                    <TableColumn fx:id="colItemQty" text="Qty" prefWidth="50"/>
                </columns>
            </TableView>
            
            <Label text="Actions" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 10 0 0 0;"/>
            <Button text="View Contact Details" maxWidth="Infinity" style="-fx-background-color: #3498db; -fx-text-fill: white;" onAction="#onViewContactDetails"/>
            <Button text="Make Payment" maxWidth="Infinity" style="-fx-background-color: #27ae60; -fx-text-fill: white;" onAction="#onPayment"/>
            <Button text="Reprint Receipt" maxWidth="Infinity" style="-fx-background-color: #f39c12; -fx-text-fill: white;" onAction="#onReprintReceipt"/>
            <Button text="Cancel Layby (Stock Refund)" maxWidth="Infinity" style="-fx-background-color: #c0392b; -fx-text-fill: white;" onAction="#onCancelLayby"/>
            <Button text="Close" maxWidth="Infinity" onAction="#onClose"/>
        </VBox>
    </right>
</BorderPane>
