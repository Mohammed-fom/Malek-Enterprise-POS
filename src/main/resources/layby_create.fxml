<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.malek.pos.controllers.LaybyCreateController">
    <children>
        <Label text="New Layby Agreement" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        
        <HBox spacing="10">
            <Label text="Total Amount:" textFill="#2c3e50"><font><Font size="16.0"/></font></Label>
            <Label fx:id="lblTotalAmount" text="0.00" textFill="#e74c3c"><font><Font name="System Bold" size="16.0"/></font></Label>
        </HBox>

        <VBox spacing="5">
            <Label text="Customer Name *" />
            <TextField fx:id="txtName" promptText="Full Name" />
        </VBox>
        
        <VBox spacing="5">
            <Label text="Phone Number *" />
            <TextField fx:id="txtPhone" promptText="Primary Contact Number" />
        </VBox>
        
        <VBox spacing="5">
            <Label text="Address *" />
            <TextArea fx:id="txtAddress" prefRowCount="3" promptText="Physical Address" />
        </VBox>
        
        <HBox spacing="20">
             <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Duration (Months)" />
                <ComboBox fx:id="cmbDuration" maxWidth="Infinity" />
             </VBox>
             
             <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Initial Deposit *" />
                <TextField fx:id="txtDeposit" promptText="0.00" />
             </VBox>
        </HBox>
        
        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Button text="Cancel" onAction="#onCancel" prefWidth="100"/>
            <Button text="Create Layby" onAction="#onCreate" prefWidth="150" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
    </children>
</VBox>
